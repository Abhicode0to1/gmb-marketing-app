# Database
DATABASE_URL=postgresql+asyncpg://gmbapp:gmbpass@db:5432/gmbdb

# Redis
REDIS_URL=redis://redis:6379/0

# JWT Auth
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Places API
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# SendGrid (Email)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=hello@yourcompany.com
SENDGRID_FROM_NAME=Your Company

# WhatsApp Business API (via Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# OR: Meta Cloud API (use one of the two)
# META_WA_PHONE_NUMBER_ID=your_phone_number_id
# META_WA_ACCESS_TOKEN=your_permanent_access_token
# META_WA_VERIFY_TOKEN=your_webhook_verify_token

# App
FRONTEND_URL=http://localhost:3000
